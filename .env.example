# Variables públicas del sitio. En local no hace falta definirlas (hay defaults).
# El despliegue en GitHub Pages las inyecta desde el workflow.

# URL raíz del despliegue (sin subpath).
#   GitHub Pages: https://nologeek.github.io
#   Dominio final: https://nolo.com.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Subpath del sitio. Vacío en local y en dominio raíz; "/vitor" en GitHub Pages.
NEXT_PUBLIC_BASE_PATH=
